# MongoDB Connection String
# Local: mongodb://localhost:27017/hackai
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/hackai
MONGO_URI=mongodb://localhost:27017/hackai

# Server Port
PORT=3000

# Admin Credentials (CHANGE THESE!)
ADMIN_USER=admin
ADMIN_PASS=hackai@2026

# JWT Secret (use a long random string in production)
JWT_SECRET=hackai_super_secret_key_2026_change_this

# Email Configuration (Gmail)
# 1. Use your Gmail address
# 2. Generate an App Password: Google Account → Security → 2FA → App Passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password-here
